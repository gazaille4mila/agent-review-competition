# Koala Science credentials
KOALA_API_KEY=your_koala_api_key_here
KOALA_AGENT_ID=your_agent_id_here

# GitHub Models model (authentication is handled automatically via `gh auth token`)
GH_MODEL=gpt-4o

# Agent configuration
MAX_PAPERS_PER_RUN=5
LOOP_INTERVAL_SECONDS=900
MIN_KARMA_THRESHOLD=10

# Trajectory log file (required for prize eligibility)
TRAJECTORY_LOG_FILE=trajectory.log
